# Authentication - NextAuth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Zitadel OIDC Configuration (using PKCE - no client secret needed)
AUTH_ZITADEL_ISSUER=https://your-zitadel-instance.zitadel.cloud
AUTH_ZITADEL_CLIENT_ID=
AUTH_ZITADEL_PROJECT_ID=

# NextAuth URL (automatically set in Vercel, needed for local dev)
NEXTAUTH_URL=http://localhost:3000

# Database - Neon PostgreSQL
DATABASE_URL=postgres://user:password@host/database?sslmode=require

# App Portal URL (for "Back to App Portal" link)
NEXT_PUBLIC_APP_PORTAL_URL=https://tools.renewalinitiatives.org

# GovInfo API — US government legal content (Federal Register, IRC, CFR, Public Laws)
# Free key: https://www.govinfo.gov/api-signup (instant, no approval)
# Used by the AI copilot's govInfoSearch tool for regulatory change detection
GOVINFO_API_KEY=

# Postmark — donor acknowledgment emails
POSTMARK_API_KEY=
POSTMARK_DONOR_ACK_TEMPLATE=donor-acknowledgment
POSTMARK_FROM_EMAIL=finance@renewalinitiatives.org

# Ramp — Corporate card integration (OAuth2 client credentials)
# Settings > Developer in Ramp dashboard → Create New App → Client Credentials grant
RAMP_CLIENT_ID=
RAMP_CLIENT_SECRET=
# RAMP_BASE_URL=https://api.ramp.com

# Plaid — Bank feed integration
# https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# CharityAPI.org — Nonprofit/charity EIN lookup
# Get keys at: https://www.charityapi.org
CHARITY_API_KEY_LIVE=
CHARITY_API_KEY_TEST=

# Encryption — AES-256-GCM key for Plaid access tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLAID_ENCRYPTION_KEY=

# Admin email — receives sync notifications and compliance reminders
ADMIN_EMAIL=

# Anthropic — AI copilot
ANTHROPIC_API_KEY=

# Cross-Neon: app-portal employee data (for payroll)
# Connection string using financial_system_reader role on app-portal's Neon DB
# Falls back to mock employees when not set
PEOPLE_DATABASE_URL=postgres://financial_system_reader:password@app-portal-host/app_portal?sslmode=require

# Cross-Neon: AES-256-GCM key for decrypting employee tax IDs from app-portal
# Must match the encryption key used by app-portal
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PEOPLE_ENCRYPTION_KEY=

# Cron job authentication
CRON_SECRET=
